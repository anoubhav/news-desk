{
  "name": "live-avatar-election-desk",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "start": "./scripts/start-local.sh",
    "serve": "node --import tsx server/index.ts",
    "pm2:start": "npx pm2 start ecosystem.config.cjs --update-env",
    "pm2:restart": "npx pm2 restart ecosystem.config.cjs --update-env",
    "pm2:stop": "npx pm2 delete live-avatar-election-desk",
    "pm2:logs": "npx pm2 logs live-avatar-election-desk",
    "test": "vitest run",
    "test:watch": "vitest",
    "hf:preview": "npm --prefix hyperframes run dev",
    "hf:check": "npm --prefix hyperframes run check",
    "hf:render-test": "npm --prefix hyperframes run render -- --out /tmp/hf-smoke.mp4"
  },
  "dependencies": {
    "@heygen/liveavatar-web-sdk": "^0.0.13",
    "@hyperframes/player": "^0.6.7",
    "@mozilla/readability": "^0.5.0",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "framer-motion": "^12.38.0",
    "jsdom": "^26.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react-swc": "^3.8.0",
    "concurrently": "^9.1.2",
    "playwright": "^1.59.1",
    "pm2": "^5.4.3",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vite": "^6.2.0",
    "vitest": "^3.0.8"
  }
}
